                    fill="none" stroke="#7d57b1" stroke-width="1.2" stroke-dasharray="3,2"/>
              <text x="603" y="50" text-anchor="middle" class="hf-target">|ψ⟩</text>
              <text x="603" y="125" text-anchor="middle" class="hf-target-sub">target modes</text>

