---
/**
 * Subject landing page for the infographics workspace.
 *
 * The SiteNav rail (left side, sticky) is also visible here so a
 * reader can jump directly to a subject without going through the
 * landing card grid. SHIPPED_SUBJECTS / PLANNED_SUBJECTS come from
 * the shared registry — the same arrays drive the rail and the cards.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import Grid from "../components/Grid.astro";
import SiteNav from "../components/SiteNav.astro";
import {
  SHIPPED_SUBJECTS,
  PLANNED_SUBJECTS,
  TIER_LABEL,
} from "../lib/subjects";
import { url } from "../lib/url";
---

<Infographic
  title="Quantum Network Infographics"
  description="Our notes from learning about quantum networking — long-scrolling pages covering qubits, entanglement, distribution, repeaters, links, protocols, and vendors."
>
  <SiteNav slot="nav" />

  <Center max="var(--wide-width)" gutter="var(--space-3)">
    <Stack space="var(--space-6)">

      <header class="hero">
        <h1>Quantum Network Infographics</h1>
        <p>
          Notes we took while learning about quantum networking, written up as
          long-scrolling pages — from <em>what is a qubit</em> through entanglement
          distribution and protocols to vendors and TRL. Not authoritative; just
          what we've understood so far. Each page stands alone.
        </p>
      </header>

      {SHIPPED_SUBJECTS.length > 0 && (
        <section aria-labelledby="available-heading">
          <h2 id="available-heading" class="group-heading">Available now</h2>
          <Grid min="22rem" gap="var(--space-3)">
            {SHIPPED_SUBJECTS.map((s) => (
              <a class="subject-card" href={url(`/${s.slug}`)}>
                <p class="subject-card__tier">{TIER_LABEL[s.tier]}</p>
                <h3>{s.title}</h3>
                <p>{s.blurb}</p>
                <span class="subject-card__cta">Open →</span>
              </a>
            ))}
          </Grid>
        </section>
      )}

      {PLANNED_SUBJECTS.length > 0 && (
        <section aria-labelledby="planned-heading">
          <h2 id="planned-heading" class="group-heading">Planned</h2>
          <p class="group-blurb">
            The reading sequence below is the build order. Subjects ship one at a time;
            the rail will start linking each as it lands.
          </p>
          <Grid min="22rem" gap="var(--space-3)">
            {PLANNED_SUBJECTS.map((s) => (
              <article class="subject-card subject-card--planned" aria-disabled="true">
                <p class="subject-card__tier">{TIER_LABEL[s.tier]}</p>
                <h3>{s.title}</h3>
                <p>{s.blurb}</p>
                <span class="subject-card__cta subject-card__cta--planned">Planned</span>
              </article>
            ))}
          </Grid>
        </section>
      )}

    </Stack>
  </Center>
</Infographic>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-4);
    border-block-end: 1px solid var(--color-rule);
    /* Match the subject-page hero rhythm: explicit grid + gap so the
       h1 → lede gap is --space-3, instead of relying on the smaller
       default <h1> margin-block-end. */
    display: grid;
    gap: var(--space-3);
  }
  .hero h1 { margin: 0; }
  .hero p  { margin: 0; }

  .group-heading {
    font-size: var(--text-2xl);
    margin-block-end: var(--space-3);
  }
  .group-blurb {
    margin-block-end: var(--space-4);
    color: var(--color-text-mute);
  }

  .subject-card {
    display: grid;
    /* Pin content to the top regardless of card height — see
       entanglement.astro .bell-card for the long-form rationale.
       Without this, subject cards in the same Grid row would
       middle-align their body once one sibling stretched the row. */
    align-content: start;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 140ms ease, transform 140ms ease;
  }
  .subject-card:hover,
  .subject-card:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .subject-card h3 {
    margin: 0;
    font-size: var(--text-xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }
  .subject-card p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-text-mute);
  }
  .subject-card__tier {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-mute);
  }
  .subject-card__cta {
    margin-block-start: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
  }

  .subject-card--planned {
    opacity: 0.65;
    border-style: dashed;
    cursor: default;
  }
  .subject-card--planned:hover {
    transform: none;
    border-color: var(--card-border);
  }
  .subject-card__cta--planned {
    color: var(--color-text-mute);
    font-weight: 400;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-surface-2);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
  }
</style>
