    margin: 0;
    padding-inline-start: var(--space-4);
    display: grid;
    gap: var(--space-2);
  }
  ol.sw-steps li { line-height: var(--leading-snug); }
  ul {
    margin: 0;
    padding-inline-start: var(--space-4);
    display: grid;
    gap: var(--space-2);
  }
