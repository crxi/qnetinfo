            </defs>

            {/* Row 1: E Gen */}
            <g data-1g-row="1" opacity="1">
              <text class="g1-lbl-stage" x="20" y="50" text-anchor="start">E Gen</text>
              <rect class="g1-dev-box" x="113" y="55" width="34" height="60" rx="5"/>
              <rect class="g1-dev-box" x="304" y="55" width="48" height="60" rx="5"/>
              <rect class="g1-dev-box" x="510" y="55" width="48" height="60" rx="5"/>
              <rect class="g1-dev-box" x="716" y="55" width="48" height="60" rx="5"/>
              <rect class="g1-dev-box" x="921" y="55" width="34" height="60" rx="5"/>
              {/* Matter qubits */}
              <circle class="g1-matter" cx="130" cy="70" r="11"/>
              <text class="g1-lbl" x="130" y="74" text-anchor="middle">A</text>
              <circle class="g1-matter" cx="316" cy="70" r="7"/>
              <circle class="g1-matter" cx="340" cy="70" r="7"/>
              <text class="g1-lbl-relay" x="328" y="45" text-anchor="middle">R₁</text>
              <circle class="g1-matter" cx="522" cy="70" r="7"/>
              <circle class="g1-matter" cx="546" cy="70" r="7"/>
              <text class="g1-lbl-relay" x="534" y="45" text-anchor="middle">R₂</text>
