            <button type="button" data-1g-ctl="back" aria-label="Step back" title="Step back">⏮</button>
            <button type="button" data-1g-ctl="play" aria-label="Pause" title="Play / pause">⏸</button>
            <button type="button" data-1g-ctl="fwd" aria-label="Step forward" title="Step forward">⏭</button>
          </div>
