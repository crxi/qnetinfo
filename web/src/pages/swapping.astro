                <line class="g1-bsm-beam" x1="190" y1="50"  x2="450" y2="310"/>
                <line class="g1-bsm-beam" x1="450" y1="310" x2="510" y2="370"/>
                <line class="g1-bsm-beam" x1="450" y1="310" x2="390" y2="370"/>
