  }

  /* Step list — each step lights up as the animation reaches it.
     Default: muted text. Active: full text colour + accent rule. */
  ol.tp-step-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 4px;
    font-size: var(--text-sm);
