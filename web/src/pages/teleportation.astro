const sections = [
  { id: "overview",   label: "Overview" },
  { id: "what",       label: "What teleportation does" },
  { id: "theory",     label: "The theory" },
  { id: "circuit",    label: "Circuit diagram" },
  { id: "math",       label: "No faster-than-light shortcut" },
  { id: "ledger",     label: "Resources and limits" },
