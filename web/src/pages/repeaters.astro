              <circle cx="680" cy="234" r="11" fill="none" stroke="#b0b6c0" stroke-width="0.8" opacity="0.4"/>
            </g>
            <g data-rp-herald-g="3">
              <circle data-rp-herald="3" cx="920" cy="234" r="7" fill="#b0b6c0" opacity="0.5"/>
              <circle cx="920" cy="234" r="11" fill="none" stroke="#b0b6c0" stroke-width="0.8" opacity="0.4"/>
            </g>

            {/* Attempt counters (below BSM apparatus) */}
            <text data-rp-attempt="0" x="200" y="335" text-anchor="middle" class="rp-attempt">attempt 1</text>
            <text data-rp-attempt="1" x="440" y="335" text-anchor="middle" class="rp-attempt">attempt 1</text>
            <text data-rp-attempt="2" x="680" y="335" text-anchor="middle" class="rp-attempt">attempt 1</text>
            <text data-rp-attempt="3" x="920" y="335" text-anchor="middle" class="rp-attempt">attempt 1</text>

            {/* ─── Bell-pair wavy paths (pink) — rebuilt at runtime ─── */}
            <path data-rp-bell-short="0" d="" fill="none" stroke="#a8408d" stroke-width="2.2" opacity="0"/>
            <path data-rp-bell-short="1" d="" fill="none" stroke="#a8408d" stroke-width="2.2" opacity="0"/>
            <path data-rp-bell-short="2" d="" fill="none" stroke="#a8408d" stroke-width="2.2" opacity="0"/>
            <path data-rp-bell-short="3" d="" fill="none" stroke="#a8408d" stroke-width="2.2" opacity="0"/>
            <path data-rp-bell-mid="0"   d="" fill="none" stroke="#a8408d" stroke-width="2.4" opacity="0"/>
            <path data-rp-bell-mid="1"   d="" fill="none" stroke="#a8408d" stroke-width="2.4" opacity="0"/>
            <path data-rp-bell-final     d="" fill="none" stroke="#a8408d" stroke-width="2.8" opacity="0"/>

            {/* ─── Matter qubit dots ───────────────────────────── */}
            {/* Node x positions: A=80, R1=320, R2=560, R3=800, B=1040 */}
