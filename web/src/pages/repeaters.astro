                </g>
                <g transform="translate(390 370) rotate(-135)">
                  <path d="M -28,0 A 28,28 0 0 0 28,0 Z" fill="#1a1f2a"/>
                </g>
                <g transform="translate(510 370) rotate(135)">
                  <path d="M -28,0 A 28,28 0 0 0 28,0 Z" fill="#1a1f2a"/>
                </g>
              </symbol>
            </defs>

            {/* ─── Backbone line ──────────────────────────────── */}
            <line x1="80" y1="180" x2="1040" y2="180" stroke="var(--color-rule)" stroke-width="1"/>

            {/* ─── Endpoint labels ────────────────────────────── */}
            <text x="80"   y="60" text-anchor="middle" class="rp-anim-label">Alice</text>
            <text x="320"  y="60" text-anchor="middle" class="rp-anim-label">R₁</text>
            <text x="560"  y="60" text-anchor="middle" class="rp-anim-label">R₂</text>
            <text x="800"  y="60" text-anchor="middle" class="rp-anim-label">R₃</text>
            <text x="1040" y="60" text-anchor="middle" class="rp-anim-label">Bob</text>

            {/* ─── BSM apparatus glyphs at four midpoints ──────── */}
            {/* midpoints: 200, 440, 680, 920; size 80×67, centred horizontally
                 around mid x, sitting in the lower half of the figure. */}
            <g data-rp-bsm-mid="0"><use href="#rp-bsm" x="160" y="240" width="80" height="67"/></g>
            <g data-rp-bsm-mid="1"><use href="#rp-bsm" x="400" y="240" width="80" height="67"/></g>
            <g data-rp-bsm-mid="2"><use href="#rp-bsm" x="640" y="240" width="80" height="67"/></g>
            <g data-rp-bsm-mid="3"><use href="#rp-bsm" x="880" y="240" width="80" height="67"/></g>

            {/* Herald indicator bulb above each BSM */}
            <g data-rp-herald-g="0">
              <circle data-rp-herald="0" cx="200" cy="234" r="7" fill="#b0b6c0" opacity="0.5"/>
              <circle cx="200" cy="234" r="11" fill="none" stroke="#b0b6c0" stroke-width="0.8" opacity="0.4"/>
            </g>
            <g data-rp-herald-g="1">
              <circle data-rp-herald="1" cx="440" cy="234" r="7" fill="#b0b6c0" opacity="0.5"/>
