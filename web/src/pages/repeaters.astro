/**
 * /repeaters — Quantum repeaters: 1G / 2G / 3G families
 *
 * Tier C · Mechanisms.
 *
 * Citations:
 *   - muralidharan-scirep-2016 — Muralidharan et al., Sci. Rep. 6, 20463
 *     (2016). The 1G/2G/3G taxonomy used here, classified by which
 *     errors (loss, operation) are suppressed probabilistically vs.
 *     deterministically.
 *   - azuma-rmp-95 — Azuma et al., RMP 95, 045006 (2023). The
 *     comprehensive review; Sec. III.B and Table V are the source
 *     for the per-generation signalling, time-scale and cost-coefficient
 *     numbers.
 *   - sangouard-rmp-83 — Sangouard et al., RMP 83, 33 (2011). 1G
 *     atomic-ensemble protocols (DLCZ-style).
 *   - bayerbach-sciadv-2023 — Bayerbach et al., Sci. Adv. 9, eadf4080
 *     (2023). Linear-optics BSM exceeding 50% with ancilla photons.
 *   - bennett-pra-1996 — BBPSSW distillation (the 2-EDP that 1G uses).
 *   - zukowski-prl-1993 — entanglement swapping.
 *   - kumar-ijndc-2025 — current network survey, 1G/2G/3G description.
 *   - jones-njp-2016 — link-architecture context (forward reference).
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
import SourceNote from "../components/SourceNote.astro";
import Callout from "../components/Callout.astro";
