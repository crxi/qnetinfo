<script type="module" is:inline>
  // 1G repeater animation. Stage timeline (each entry = ms duration at
  // realistic settings, used for both autoplay pacing and the scrubber
  // mapping). Stages:
  //   EG_EARLY  — photons in flight, no heralds yet.
  //   EG_MID    — some links heralded, others still retrying.
  //   EG_POST   — all four short Bell pairs established (wavy pink).
  //   ES1_START — BSM boxes fade in at R1 and R3.
  //   ES1_END   — short pairs merged into two longer wavy lines; R1/R3 grey.
  //   ES2_START — BSM box at R2 fades in.
  //   ES2_END   — one wavy A↔B line; all interior dots grey.
  //   HOLD      — final state, brief glow.
  // The scrubber maps a 0-1000 slider position onto this timeline.
  const fig = document.querySelector("[data-rp]");
  if (fig) {
    const svg     = fig.querySelector("[data-rp-svg]");
    const badge   = fig.querySelector("[data-rp-badge]");

    const heralds  = [0,1,2,3].map(i => svg.querySelector(`[data-rp-herald="${i}"]`));
    const attempts = [0,1,2,3].map(i => svg.querySelector(`[data-rp-attempt="${i}"]`));
    const photL    = [0,1,2,3].map(i => svg.querySelector(`[data-rp-photon="${i}-L"]`));
    const photR    = [0,1,2,3].map(i => svg.querySelector(`[data-rp-photon="${i}-R"]`));
    const tethL    = [0,1,2,3].map(i => svg.querySelector(`[data-rp-tether="${i}-L"]`));
    const tethR    = [0,1,2,3].map(i => svg.querySelector(`[data-rp-tether="${i}-R"]`));
    const shortB   = [0,1,2,3].map(i => svg.querySelector(`[data-rp-bell-short="${i}"]`));
    const midB     = [0,1].map(i   => svg.querySelector(`[data-rp-bell-mid="${i}"]`));
    const finalB   = svg.querySelector("[data-rp-bell-final]");
    const relayBSM = {
      R1: svg.querySelector('[data-rp-relay-bsm="R1"]'),
      R2: svg.querySelector('[data-rp-relay-bsm="R2"]'),
      R3: svg.querySelector('[data-rp-relay-bsm="R3"]'),
    };
    const dotA   = svg.querySelector('[data-rp-dot="A-R"]');
    const dotR1L = svg.querySelector('[data-rp-dot="R1-L"]');
    const dotR1R = svg.querySelector('[data-rp-dot="R1-R"]');
    const dotR2L = svg.querySelector('[data-rp-dot="R2-L"]');
    const dotR2R = svg.querySelector('[data-rp-dot="R2-R"]');
    const dotR3L = svg.querySelector('[data-rp-dot="R3-L"]');
    const dotR3R = svg.querySelector('[data-rp-dot="R3-R"]');
    const dotB   = svg.querySelector('[data-rp-dot="B-L"]');

    // Source dot positions (left-photon source, right-photon source) per link
    // and midpoint coordinates.
    const SRC_Y = 180;
    const MID_Y = 274;       // photons converge into the BSM apparatus body
    const PARK_Y = 205;      // launch (emission) point, just below matter qubit
    const LINKS = [
      { srcL: 96,   srcR: 306,  midX: 200 }, // A  ↔ R1
      { srcL: 334,  srcR: 546,  midX: 440 }, // R1 ↔ R2
      { srcL: 574,  srcR: 786,  midX: 680 }, // R2 ↔ R3
      { srcL: 814,  srcR: 1024, midX: 920 }, // R3 ↔ B
    ];
    // Dot anchor x for each side of each link (matter-qubit centres).
    const DOTS_X = [
      [96,   306],
      [334,  546],
      [574,  786],
      [814, 1024],
    ];

    const setOp   = (el, v) => el && el.setAttribute("opacity", String(v));
    const setFill = (g, c)  => { if (g) g.querySelector("circle").setAttribute("fill", c); };
    const setBadge = (label, kind) => {
      badge.textContent = label;
      badge.dataset.kind = kind;
    };

    // ─── Wavy Bell-line builder, same idiom as teleportation.astro ───
    function wavyPath(ax, ay, bx, by) {
      const dx = bx - ax, dy = by - ay;
      const len = Math.hypot(dx, dy);
      if (len < 1) return "";
      const nx = -dy / len, ny = dx / len;
      const wavelength = 14, amp = 5;
      const segments = Math.max(40, Math.round(len / 2));
      let d = `M ${ax} ${ay}`;
      for (let i = 1; i < segments; i++) {
        const t = i / segments;
        const baseX = ax + dx * t;
        const baseY = ay + dy * t;
        const phase = (t * len / wavelength) * 2 * Math.PI;
        const off = Math.sin(phase) * amp;
        d += ` L ${baseX + nx * off} ${baseY + ny * off}`;
      }
      d += ` L ${bx} ${by}`;
      return d;
    }
    function drawShort(i) {
      const [a, b] = DOTS_X[i];
      shortB[i].setAttribute("d", wavyPath(a + 9, SRC_Y, b - 9, SRC_Y));
    }
    function drawMid0() {
      midB[0].setAttribute("d", wavyPath(96 + 9, SRC_Y, 546 - 9, SRC_Y));
    }
    function drawMid1() {
      midB[1].setAttribute("d", wavyPath(574 + 9, SRC_Y, 1024 - 9, SRC_Y));
    }
    function drawFinal() {
      finalB.setAttribute("d", wavyPath(96 + 9, SRC_Y, 1024 - 9, SRC_Y));
    }
    drawShort(0); drawShort(1); drawShort(2); drawShort(3);
    drawMid0(); drawMid1(); drawFinal();

    // ─── Stage definitions and scrubber mapping ────────────────────
    // Stage keys map to (a) the explainer paragraph, (b) the badge label,
    // and (c) a chunk of the scrubber [0..1000].
    const STAGES = [
      { key: "EG_EARLY", label: "EG · attempts in flight",         span: 180, panel: "EG"   },
      { key: "EG_MID",   label: "EG · some heralded, some retry",  span: 180, panel: "EG"   },
      { key: "EG_POST",  label: "EG · all four pairs established", span: 100, panel: "EG"   },
      { key: "ES1_IN",   label: "1st ES · R₁ and R₃ measure",      span: 100, panel: "ES1"  },
      { key: "ES1_OUT",  label: "1st ES · two longer pairs",       span: 100, panel: "ES1"  },
      { key: "ES2_IN",   label: "2nd ES · R₂ measures",            span: 100, panel: "ES2"  },
      { key: "ES2_OUT",  label: "2nd ES · end-to-end Bell pair",   span: 100, panel: "ES2"  },
      { key: "HOLD",     label: "result · entanglement delivered", span: 140, panel: "HOLD" },
    ];
    const TOTAL = STAGES.reduce((s, x) => s + x.span, 0);
    // pre-compute start offsets in slider units (0..1000)
    let acc = 0;
    const STAGE_START = STAGES.map(s => { const o = acc; acc += s.span; return o; });
    function sliderForStage(idx, frac = 0) {
      return Math.round(((STAGE_START[idx] + frac * STAGES[idx].span) / TOTAL) * 1000);
    }
    function stageFromSlider(v) {
      const u = (v / 1000) * TOTAL;
      let cum = 0;
      for (let i = 0; i < STAGES.length; i++) {
        const next = cum + STAGES[i].span;
        if (u < next || i === STAGES.length - 1) {
          return { idx: i, frac: Math.max(0, Math.min(1, (u - cum) / STAGES[i].span)) };
        }
        cum = next;
      }
      return { idx: STAGES.length - 1, frac: 1 };
    }

    // ─── Per-cycle randomised plan (which attempt each link succeeds on,
    //     plus the result of each ES). Re-rolled every time we restart EG. */
    let P_EG = 0.5, P_ES = 0.85;
    let plan = null;
    function rollPlan() {
      // sample geometric attempts per link
      const linkAttempts = [];
      for (let i = 0; i < 4; i++) {
        if (P_EG >= 0.999) { linkAttempts.push(1); continue; }
        // cap at 8 to keep the counter sane on screen
        let n = 1;
        while (n < 8 && Math.random() >= P_EG) n++;
        linkAttempts.push(n);
      }
      // ES success — with probability 1-P_ES retry would happen, but for
      // visual clarity we treat ES as deterministic per stage and only
      // flicker the herald colour during the IN-half of the stage.
      const es1okR1 = Math.random() < P_ES;
      const es1okR3 = Math.random() < P_ES;
      const es2ok   = Math.random() < P_ES;
      // Max attempts drives the per-link visible attempt counter.
      const maxN = Math.max(...linkAttempts);
      plan = { linkAttempts, maxN, es1okR1, es1okR3, es2ok };
    }

    // ─── Frame renderer: given (stageIdx, frac in [0,1]) draw the SVG ───
    function renderFrame(idx, frac) {
      const stage = STAGES[idx];
      setBadge(stage.label, stage.key);
      // Update stage name in controls
      stageName.textContent = stage.label;
      // Update explainer panel
      for (const p of paras) {
        p.classList.toggle("is-active", p.dataset.rpPara === stage.panel);
      }

      // ── Default: hide transient layers, restore dot fills ──
      for (let i = 0; i < 4; i++) {
        setOp(photL[i], 0); setOp(photR[i], 0);
        setOp(tethL[i], 0); setOp(tethR[i], 0);
        heralds[i].setAttribute("fill", "#b0b6c0");
        setOp(heralds[i], 0.5);
        setOp(attempts[i], 1);
        attempts[i].textContent = "attempt 1";
        setOp(shortB[i], 0);
      }
      setOp(midB[0], 0); setOp(midB[1], 0);
      setOp(finalB, 0);
      setOp(relayBSM.R1, 0); setOp(relayBSM.R2, 0); setOp(relayBSM.R3, 0);
      for (const g of [dotA, dotR1L, dotR1R, dotR2L, dotR2R, dotR3L, dotR3R, dotB]) {
        setFill(g, "#2ea043");
      }

      if (!plan) rollPlan();

      // ─── Stage-specific drawing ───
      const key = stage.key;
      if (key === "EG_EARLY" || key === "EG_MID" || key === "EG_POST") {
        // Each link: based on frac, how many attempts have we resolved?
        // We unfold the maxN attempts evenly across EG_EARLY + EG_MID
        // (which together represent the multi-attempt phase). EG_POST
        // is a "everything heralded, hold" sub-stage.
        const totalEgFrac = key === "EG_EARLY"
          ? frac * 0.5
          : key === "EG_MID"
            ? 0.5 + frac * 0.5
            : 1;

        for (let i = 0; i < 4; i++) {
          const myN = plan.linkAttempts[i];     // attempt on which this link finally succeeds
          const myProgress = totalEgFrac * plan.maxN; // global attempt clock
          const myAttempt = Math.min(myN, Math.floor(myProgress) + 1);
          const succeeded = myProgress >= myN;
          attempts[i].textContent = succeeded
            ? (myN === 1 ? "heralded" : `heralded · ${myN} attempts`)
            : `attempt ${myAttempt}`;
          if (succeeded) {
            setOp(shortB[i], 0.95);
            heralds[i].setAttribute("fill", "#2ea043");
            setOp(heralds[i], 1);
          } else {
            // photons mid-flight; phase within the current attempt
            const tInAttempt = myProgress - (myAttempt - 1);
            const link = LINKS[i];
            // 0..0.7 = flight, 0.7..1 = verdict (red flash if not final attempt)
            if (tInAttempt < 0.7) {
              const tt = tInAttempt / 0.7;
              const xL = link.srcL + (link.midX - link.srcL) * tt;
              const yL = PARK_Y + (MID_Y - PARK_Y) * tt;
              const xR = link.srcR + (link.midX - link.srcR) * tt;
              const yR = PARK_Y + (MID_Y - PARK_Y) * tt;
              photL[i].setAttribute("transform", `translate(${xL} ${yL})`);
              photR[i].setAttribute("transform", `translate(${xR} ${yR})`);
              setOp(photL[i], 1); setOp(photR[i], 1);
              setOp(tethL[i], 0.5); setOp(tethR[i], 0.5);
            } else {
              // verdict: failure flash
              heralds[i].setAttribute("fill", "#c0392b");
              setOp(heralds[i], 1);
            }
          }
        }
        return;
      }

      // After EG: all four short pairs are established as a baseline.
      function showAllShort() {
        for (let i = 0; i < 4; i++) {
          setOp(shortB[i], 0.95);
          attempts[i].textContent = plan.linkAttempts[i] === 1
            ? "heralded" : `heralded · ${plan.linkAttempts[i]} attempts`;
          heralds[i].setAttribute("fill", "#2ea043");
          setOp(heralds[i], 1);
        }
      }

      if (key === "ES1_IN") {
        showAllShort();
        // BSM dashed boxes fade in at R1 and R3
        const f = Math.min(1, frac * 1.4);
        setOp(relayBSM.R1, f);
        setOp(relayBSM.R3, f);
        return;
      }

      if (key === "ES1_OUT") {
        // Swaps complete — short pairs gone, two mid pairs present, R1/R3 grey.
        setOp(relayBSM.R1, 0.55);
        setOp(relayBSM.R3, 0.55);
        for (let i = 0; i < 4; i++) setOp(shortB[i], 0);
        setOp(midB[0], 0.95); setOp(midB[1], 0.95);
        for (const g of [dotR1L, dotR1R, dotR3L, dotR3R]) setFill(g, "#b0b6c0");
        for (let i = 0; i < 4; i++) setOp(attempts[i], 0);
        return;
      }

      if (key === "ES2_IN") {
        // Carry forward ES1_OUT state, then fade in R2 box
        setOp(relayBSM.R1, 0.55);
        setOp(relayBSM.R3, 0.55);
        for (let i = 0; i < 4; i++) setOp(shortB[i], 0);
        setOp(midB[0], 0.95); setOp(midB[1], 0.95);
        for (const g of [dotR1L, dotR1R, dotR3L, dotR3R]) setFill(g, "#b0b6c0");
        for (let i = 0; i < 4; i++) setOp(attempts[i], 0);
        const f = Math.min(1, frac * 1.4);
        setOp(relayBSM.R2, f);
        return;
      }

      if (key === "ES2_OUT" || key === "HOLD") {
        setOp(relayBSM.R1, 0.55);
        setOp(relayBSM.R2, 0.55);
        setOp(relayBSM.R3, 0.55);
        for (let i = 0; i < 4; i++) { setOp(shortB[i], 0); setOp(attempts[i], 0); }
        setOp(midB[0], 0); setOp(midB[1], 0);
        for (const g of [dotR1L, dotR1R, dotR2L, dotR2R, dotR3L, dotR3R]) setFill(g, "#b0b6c0");
        if (key === "HOLD") {
          // gentle glow on the final pair
          const glow = 2.8 + 0.5 * Math.sin(frac * Math.PI * 4);
          finalB.setAttribute("stroke-width", String(glow));
        } else {
          finalB.setAttribute("stroke-width", "2.8");
        }
        setOp(finalB, 1);
        return;
      }
    }

    // ─── Controls wiring ───
    const playBtn   = fig.querySelector("[data-rp-play]");
    const scrub     = fig.querySelector("[data-rp-scrub]");
    const stageName = fig.querySelector("[data-rp-stage-name]");
    const paras     = Array.from(fig.querySelectorAll("[data-rp-para]"));
    const customBox = fig.querySelector("[data-rp-custom]");
    const pegInput  = fig.querySelector("[data-rp-peg]");
    const pesInput  = fig.querySelector("[data-rp-pes]");
    const pegVal    = fig.querySelector("[data-rp-peg-val]");
    const pesVal    = fig.querySelector("[data-rp-pes-val]");
    const modeInputs = Array.from(fig.querySelectorAll('input[name="rp-mode"]'));

    const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

    function applyMode(mode) {
      if (mode === "ideal") {
        P_EG = 1.0; P_ES = 1.0;
        customBox.hidden = true;
      } else if (mode === "realistic") {
        P_EG = 0.5; P_ES = 0.85;
        customBox.hidden = true;
      } else {
        P_EG = parseInt(pegInput.value, 10) / 100;
        P_ES = parseInt(pesInput.value, 10) / 100;
        customBox.hidden = false;
      }
      pegVal.textContent = P_EG.toFixed(2);
      pesVal.textContent = P_ES.toFixed(2);
      // re-roll for the next cycle so changes are visible immediately
      rollPlan();
    }
    for (const r of modeInputs) {
      r.addEventListener("change", () => applyMode(r.value));
    }
    pegInput.addEventListener("input", () => {
      P_EG = parseInt(pegInput.value, 10) / 100;
      pegVal.textContent = P_EG.toFixed(2);
      rollPlan();
    });
    pesInput.addEventListener("input", () => {
      P_ES = parseInt(pesInput.value, 10) / 100;
      pesVal.textContent = P_ES.toFixed(2);
      rollPlan();
    });

    // ─── Reduced-motion: render the final state and disable controls ───
    if (reducedMotion) {
      rollPlan();
      renderFrame(STAGES.length - 1, 1);
      scrub.value = 1000;
      scrub.disabled = true;
      playBtn.disabled = true;
      playBtn.textContent = "Play";
      for (const i of modeInputs) i.disabled = true;
      pegInput.disabled = true;
      pesInput.disabled = true;
      return;
    }

    // ─── Autoplay engine ───
    // ms per slider unit at realistic settings. Total cycle ≈ TOTAL * MS_PER_UNIT.
    const MS_PER_UNIT = 13;  // TOTAL=1000 → ~13s per full cycle
    let playing = true;
    let last = performance.now();
    let sliderPos = 0;
    let scrubbing = false;
    let raf = 0;
    let visible = false;

    rollPlan();
    renderFrame(0, 0);

    function tick(now) {
      if (visible && playing && !scrubbing) {
        const dt = now - last;
        sliderPos += dt / MS_PER_UNIT;
        if (sliderPos >= 1000) {
          sliderPos = 0;
          rollPlan();
        }
        scrub.value = String(Math.round(sliderPos));
        const { idx, frac } = stageFromSlider(sliderPos);
        renderFrame(idx, frac);
      }
      last = now;
      raf = requestAnimationFrame(tick);
    }

    playBtn.addEventListener("click", () => {
      playing = !playing;
      playBtn.textContent = playing ? "Pause" : "Play";
      last = performance.now();
    });

    scrub.addEventListener("input", () => {
      scrubbing = true;
      playing = false;
      playBtn.textContent = "Play";
      sliderPos = parseInt(scrub.value, 10);
      const { idx, frac } = stageFromSlider(sliderPos);
      renderFrame(idx, frac);
    });
    scrub.addEventListener("change", () => {
      scrubbing = false;
    });

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        visible = entry.isIntersecting;
        if (visible) last = performance.now();
      }
    }, { threshold: 0.15 });
    observer.observe(fig);
    raf = requestAnimationFrame(tick);
  }
</script>

