                <line x1="450" y1="310" x2="510" y2="370" stroke="#5a6472" stroke-width="6" stroke-linecap="round"/>
                <line x1="450" y1="310" x2="390" y2="370" stroke="#5a6472" stroke-width="6" stroke-linecap="round"/>
                <line x1="450" y1="50"  x2="190" y2="310" stroke="#5a6472" stroke-width="6" stroke-linecap="round"/>
                <line x1="190" y1="310" x2="130" y2="370" stroke="#5a6472" stroke-width="6" stroke-linecap="round"/>
                <line x1="190" y1="310" x2="250" y2="370" stroke="#5a6472" stroke-width="6" stroke-linecap="round"/>
                {/* Central 50:50 beam splitter — solid vertical bar */}
                <rect x="312" y="140" width="16" height="80" rx="4" fill="#1a1f2a"/>
                {/* Two PBS diamonds with vertical coating lines */}
                <polygon points="190,270 230,310 190,350 150,310"
                         fill="#d9eef9" stroke="#000" stroke-width="6" stroke-linejoin="round"/>
                <line x1="190" y1="270" x2="190" y2="350" stroke="#000" stroke-width="5" stroke-linecap="round"/>
                <polygon points="450,270 490,310 450,350 410,310"
                         fill="#d9eef9" stroke="#000" stroke-width="6" stroke-linejoin="round"/>
                <line x1="450" y1="270" x2="450" y2="350" stroke="#000" stroke-width="5" stroke-linecap="round"/>
                {/* Four D-shape detectors */}
                <g transform="translate(130 370) rotate(-135)">
                  <path d="M -28,0 A 28,28 0 0 0 28,0 Z" fill="#1a1f2a"/>
                </g>
                <g transform="translate(250 370) rotate(135)">
