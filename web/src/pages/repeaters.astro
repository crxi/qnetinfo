            <g data-rp-dot="R1-L" transform="translate(306 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>
            <g data-rp-dot="R1-R" transform="translate(334 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>
            <g data-rp-dot="R2-L" transform="translate(546 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>
            <g data-rp-dot="R2-R" transform="translate(574 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>
            <g data-rp-dot="R3-L" transform="translate(786 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>
            <g data-rp-dot="R3-R" transform="translate(814 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>
            <g data-rp-dot="B-L"  transform="translate(1024 180)"><circle r="9" fill="#2ea043" stroke="#1a1f2a" stroke-width="1.2"/></g>

            {/* ─── Photon glyphs (blue) — sit BELOW their matter qubit at
                 rest and travel down then in toward the BSM. */}
            <g data-rp-photon="0-L" opacity="0"><circle r="5" fill="#3b82f6"/><circle r="9" fill="#3b82f6" opacity="0.25"/></g>
            <g data-rp-photon="0-R" opacity="0"><circle r="5" fill="#3b82f6"/><circle r="9" fill="#3b82f6" opacity="0.25"/></g>
            <g data-rp-photon="1-L" opacity="0"><circle r="5" fill="#3b82f6"/><circle r="9" fill="#3b82f6" opacity="0.25"/></g>
            <g data-rp-photon="1-R" opacity="0"><circle r="5" fill="#3b82f6"/><circle r="9" fill="#3b82f6" opacity="0.25"/></g>
            <g data-rp-photon="2-L" opacity="0"><circle r="5" fill="#3b82f6"/><circle r="9" fill="#3b82f6" opacity="0.25"/></g>
            <g data-rp-photon="2-R" opacity="0"><circle r="5" fill="#3b82f6"/><circle r="9" fill="#3b82f6" opacity="0.25"/></g>
