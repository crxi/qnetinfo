                qubit down to photon launch point). */}
            <line data-rp-tether="0-L" x1="96"   y1="189" x2="96"   y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="0-R" x1="306"  y1="189" x2="306"  y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="1-L" x1="334"  y1="189" x2="334"  y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="1-R" x1="546"  y1="189" x2="546"  y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="2-L" x1="574"  y1="189" x2="574"  y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="2-R" x1="786"  y1="189" x2="786"  y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="3-L" x1="814"  y1="189" x2="814"  y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>
            <line data-rp-tether="3-R" x1="1024" y1="189" x2="1024" y2="210" stroke="#3b82f6" stroke-width="1" opacity="0"/>

