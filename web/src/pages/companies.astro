---
/**
 * /companies — Vendor landscape (landing page)
 *
 * Tier E · Applications & market.
 *
 * The landing reads every YAML in qnetinfo/companies/ via the companies
 * loader and groups vendors by primary category. The textual platform
 * lists below (transmon / trapped-ion / etc.) survive as a static
 * snapshot for vendors that don't have a dossier yet — once a dossier
 * lands in qnetinfo/companies/<slug>.yaml, the vendor's name on this
 * landing page can be promoted to a link to its sub-page.
 *
 * Citations:
 *   - ezratty-uqt-2025-p2 — survey-level coverage of the vendor landscape.
 *   - meddeb-comnet-2025 — per-platform R&D status.
 *   - kumar-ijndc-2025 — survey-level positioning.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
import SourceNote from "../components/SourceNote.astro";
import CompanyLogo from "../components/CompanyLogo.astro";
import {
  COMPANIES,
  CATEGORY_LABEL,
  CATEGORY_ORDER,
  companiesByPrimary,
  type Company,
} from "../lib/companies.ts";

const sections = [
  { id: "overview",   label: "Overview" },
  { id: "dossiers",   label: "Vendor dossiers" },
  { id: "watching",   label: "Other vendors we're watching" },
  { id: "notes",      label: "Notes on this page" },
];

// Group dossiers by primary category, in the canonical CATEGORY_ORDER.
const grouped: { category: typeof CATEGORY_ORDER[number]; companies: Company[] }[] =
  CATEGORY_ORDER
    .map((c) => ({ category: c, companies: companiesByPrimary(c) }))
    .filter((g) => g.companies.length > 0);

const haveDossiers = COMPANIES.length > 0;

// Chip counts: how many dossiers fall under each primary category.
const dossierCategoryCounts: Partial<Record<typeof CATEGORY_ORDER[number], number>> =
  Object.fromEntries(grouped.map((g) => [g.category, g.companies.length]));

// Vendors named in surveys but not yet in our dossier set — flat list grouped by family.
const watchList: { family: string; companies: { name: string; note: string }[] }[] = [
  {
    family: "Computer vendors",
    companies: [
      { name: "Google",              note: "transmon; Sycamore lineage." },
      { name: "IQM",                 note: "transmon; multi-chip systems." },
      { name: "USTC",                note: "transmon; Jiuzhang and Zuchongzhi families (research org, not a vendor)." },
      { name: "AQT",                 note: "Ca⁺ / Yb⁺ trapped-ion; rack-mounted systems." },
      { name: "Universal Quantum",   note: "Yb⁺ networked-ion modules." },
      { name: "Infleqtion (ColdQuanta)", note: "Rb neutral-atom compute + sensing." },
      { name: "ORCA Computing",      note: "photonic memory-based; squeezed-light approach." },
      { name: "QuiX Quantum",        note: "photonic linear-optical processors." },
      { name: "Lightsynq",           note: "SiV-centre memory nodes for the quantum internet." },
      { name: "Quantum Brilliance",  note: "NV-centre room-temperature appliances." },
      { name: "Microsoft",           note: "Majorana-zero-mode qubits; long-running topological programme." },
    ],
  },
  {
    family: "Networking & QKD",
    companies: [
      { name: "MagiQ Technologies",     note: "QKD endpoints." },
      { name: "Quantum Bridge Tech",    note: "quantum-network infrastructure for QKD and entanglement distribution." },
    ],
  },
  {
    family: "Components",
    companies: [
      { name: "memQ",            note: "Er³⁺-doped telecom-band quantum memories (Argonne / Awschalom-group spinout)." },
      { name: "Sparrow Quantum", note: "quantum-dot single-photon source devices." },
      { name: "Element Six",     note: "synthetic-diamond foundry; substrates for NV / SiV memory nodes." },
    ],
  },
];
---

<Infographic
  title="Companies — vendor landscape"
  description="A growing index of vendors building quantum-network hardware and applications. Each tracked vendor has a deep-dive sub-page with milestones, roadmap, and capability metrics."
  references={[
    "ezratty-uqt-2025-p2",
    "kumar-ijndc-2025",
    "meddeb-comnet-2025",
  ]}
>
  <SiteNav slot="nav" currentSubject="companies" sections={sections} />

  <Center max="var(--wide-width)" gutter="var(--space-3)">
    <Stack space="var(--space-6)">

      <header class="hero" id="overview" data-nav-section>
        <h1>Companies — vendor landscape</h1>
        <p>
          A quantum-networking workspace that doesn't track vendors loses touch with what
          can actually be procured. This page has two layers: a deep-dive dossier per
          vendor — milestones, roadmap, capability metrics, all cited to primary sources
          — and a static landscape snapshot for vendors where the dossier hasn't been
          written yet <SourceNote id="ezratty-uqt-2025-p2" /><SourceNote id="meddeb-comnet-2025" />.
        </p>
        <p>
          Vendors split naturally into three buckets: <strong>computers</strong> (build
          quantum processors), <strong>networking &amp; QKD</strong> (build the network
          fabric or the QKD endpoints), and <strong>components</strong> (build the
          memories, sources, and other infrastructure that the other two consume).
        </p>
      </header>

      <section id="dossiers" data-nav-section>
        <h2>Vendor dossiers</h2>
        {haveDossiers ? (
          <p>
            Each dossier below links to a per-vendor page with milestones, roadmap, and
            modality-specific capability details. Compiled from primary sources (papers,
            vendor technology pages); see each page for source links. Use the search
            box and category chips to narrow the grid.
          </p>
        ) : (
          <p class="empty">No dossiers compiled yet.</p>
        )}

        {haveDossiers && (
          <div class="filter-bar" id="co-filter-bar">
            <input type="search" id="co-search" placeholder="Search name, positioning, location…" class="co-search" />
            <div class="filter-chips" data-filter-group="category">
              {CATEGORY_ORDER.filter((c) => (dossierCategoryCounts[c] ?? 0) > 0).map((c) => (
                <button class="chip cat-chip" data-filter-value={c} aria-pressed="false" type="button">
                  {CATEGORY_LABEL[c]}
                  <span class="chip-count">{dossierCategoryCounts[c]}</span>
                </button>
              ))}
            </div>
            <button id="co-reset" class="co-reset" type="button">Reset</button>
          </div>
        )}

        <div id="co-dossiers">
          {grouped.map((group) => (
            <div class="dossier-group" data-group-cat={group.category}>
              <h3 class="dossier-group-title">{CATEGORY_LABEL[group.category]}</h3>
              <ul class="dossier-grid">
                {group.companies.map((c) => (
                  <li
                    class="dossier-card"
                    data-categories={c.categories.join(" ")}
                    data-search={`${c.name} ${c.positioning ?? ""} ${c.hq ?? ""} ${c.categories.map((cc) => CATEGORY_LABEL[cc]).join(" ")}`.toLowerCase()}
                  >
                    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/companies/${c.slug}`}>
                      <div class="dossier-head">
                        <CompanyLogo name={c.name} logo={c.logo} size={32} />
                        <div class="dossier-name">{c.name}</div>
                      </div>
                      <div class="dossier-positioning">{c.positioning}</div>
                      <div class="dossier-meta">
                        {c.categories.length > 1 && (
                          <span class="dossier-extra-cats">
                            also: {c.categories.slice(1).map((cc) => CATEGORY_LABEL[cc]).join(", ")}
                          </span>
                        )}
                        <span class="dossier-hq">{c.hq}</span>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <p id="co-empty" class="co-empty" hidden>No dossiers match the current filters.</p>
      </section>

      <section id="watching" data-nav-section>
        <h2>Other vendors we're watching</h2>
        <p>
          Vendors named in the survey literature that don't have a dossier yet. Each
          is a candidate to promote once we've sourced the milestones and capability
          metrics. The dossier grid above is the long-term tracking surface; this
          list is the queue.
        </p>
        {watchList.map((group) => (
          <div class="watch-group">
            <h3 class="watch-group-title">{group.family}</h3>
            <ul class="watch-list">
              {group.companies.map((c) => (
                <li><strong>{c.name}</strong> — {c.note}</li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <section id="notes" data-nav-section>
        <h2>Notes on this page</h2>
        <ul>
          <li>
            <strong>The landscape snapshot is a starting point.</strong> Names + platforms
            + one-line positions, drawn from survey literature. Goes stale within months.
          </li>
          <li>
            <strong>Dossiers are the long-term tracking surface.</strong> Milestones,
            roadmap, capability metrics, and citations. Fields the dossier couldn't
            verify to a primary source are shown as <em>unverified</em> rather than
            filled in with a guess.
          </li>
          <li>
            <strong>Source priority for dossiers:</strong> peer-reviewed paper &gt; arXiv
            preprint &gt; vendor blog or technology page &gt; press release &gt; industry
            tracker. Wikipedia is acceptable only for company-history facts, never for
            technical numbers.
          </li>
          <li>
            <strong>Staleness.</strong> Each dossier records when it was last verified.
            Entries older than three months get a <em>stale</em> badge on the dossier
            page — a prompt to re-check the primary sources.
          </li>
        </ul>
        <p>
          For survey-level reference on the per-platform vendor landscape, see Ezratty
          UQT Pt 2 <SourceNote id="ezratty-uqt-2025-p2" /> and Kumar 2025
          IJNDC <SourceNote id="kumar-ijndc-2025" />.
        </p>
      </section>

    </Stack>
  </Center>
</Infographic>

<script is:inline>
  (function () {
    const bar = document.getElementById("co-filter-bar");
    if (!bar) return;
    const search = /** @type {HTMLInputElement} */ (document.getElementById("co-search"));
    const reset  = document.getElementById("co-reset");
    const empty  = document.getElementById("co-empty");
    const chips  = Array.from(bar.querySelectorAll(".cat-chip"));
    const cards  = Array.from(document.querySelectorAll("#co-dossiers .dossier-card"));
    const groups = Array.from(document.querySelectorAll("#co-dossiers .dossier-group"));

    const activeCats = new Set();
    let query = "";

    function apply() {
      let visibleTotal = 0;
      for (const card of cards) {
        const cats = (card.getAttribute("data-categories") || "").split(/\s+/).filter(Boolean);
        const searchText = card.getAttribute("data-search") || "";
        const matchesCat = activeCats.size === 0 || cats.some((c) => activeCats.has(c));
        const matchesQuery = query === "" || searchText.indexOf(query) !== -1;
        const visible = matchesCat && matchesQuery;
        card.hidden = !visible;
        if (visible) visibleTotal++;
      }
      // Hide whole group when all its cards are hidden.
      for (const group of groups) {
        const anyVisible = Array.from(group.querySelectorAll(".dossier-card"))
          .some((el) => !el.hidden);
        group.hidden = !anyVisible;
      }
      if (empty) empty.hidden = visibleTotal !== 0;
    }

    search.addEventListener("input", () => {
      query = search.value.trim().toLowerCase();
      apply();
    });

    for (const chip of chips) {
      chip.addEventListener("click", () => {
        const v = chip.getAttribute("data-filter-value");
        if (!v) return;
        if (activeCats.has(v)) {
          activeCats.delete(v);
          chip.setAttribute("aria-pressed", "false");
        } else {
          activeCats.add(v);
          chip.setAttribute("aria-pressed", "true");
        }
        apply();
      });
    }

    reset?.addEventListener("click", () => {
      activeCats.clear();
      query = "";
      search.value = "";
      for (const c of chips) c.setAttribute("aria-pressed", "false");
      apply();
    });
  })();
</script>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-4);
    display: grid;
    gap: var(--space-3);
  }
  .hero h1 { margin: 0; }
  .hero p { margin: 0; }

  section { display: grid; gap: var(--space-3); }
  section h3.vendor-platform {
    margin: 0;
    margin-block-start: var(--space-2);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  ul {
    margin: 0;
    padding-inline-start: var(--space-4);
    display: grid;
    gap: var(--space-2);
  }
  li { line-height: var(--leading-snug); }

  .vendor-list li { color: var(--color-text-mute); }
  .vendor-list strong { color: var(--color-text); }

  /* Dossier grid */
  .dossier-group { display: grid; gap: var(--space-2); margin-block-end: var(--space-3); }
  .dossier-group-title {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text);
  }
  .dossier-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(340px, 100%), 1fr));
    max-inline-size: min(100%, 1100px);
    gap: var(--space-2);
  }
  .dossier-card {
    padding: 0;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    transition: border-color 150ms ease;
  }
  .dossier-card:hover { border-color: var(--color-accent); }
  .dossier-card a {
    display: grid;
    gap: 6px;
    padding: var(--space-3);
    color: inherit;
    text-decoration: none;
  }
  .dossier-head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .dossier-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--text-md);
  }
  .dossier-positioning {
    font-size: var(--text-sm);
    color: var(--color-text-mute);
    line-height: var(--leading-snug);
  }
  .dossier-meta {
    margin-block-start: var(--space-1);
    display: flex; gap: var(--space-2); flex-wrap: wrap;
    font-size: var(--text-xs); color: var(--color-text-mute);
  }
  .dossier-extra-cats { color: var(--color-accent); }
  .empty { color: var(--color-text-mute); }

  /* ─── Filter bar ─────────────────────────────────────────── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-block: var(--space-3) var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface-2);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
  }
  .co-search {
    flex: 1 1 16rem;
    min-width: 12rem;
    font-size: var(--text-sm);
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    background: var(--card-bg);
    color: var(--color-text);
  }
  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font: inherit;
    font-size: var(--text-xs);
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--color-rule);
    background: var(--card-bg);
    border-radius: 999px;
    cursor: pointer;
    color: var(--color-text);
    transition: background 120ms, border-color 120ms;
  }
  .chip:hover { border-color: var(--color-accent); }
  .chip[aria-pressed="true"] {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }
  .chip-count {
    font-size: 0.85em;
    opacity: 0.7;
  }
  .co-reset {
    font: inherit;
    font-size: var(--text-xs);
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-rule);
    background: transparent;
    color: var(--color-text-mute);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .co-reset:hover { color: var(--color-text); border-color: var(--color-accent); }
  .co-empty {
    color: var(--color-text-mute);
    font-style: italic;
    margin-block-start: var(--space-3);
  }

  /* ─── Watch list ─────────────────────────────────────────── */
  .watch-group + .watch-group { margin-block-start: var(--space-3); }
  .watch-group-title {
    font-size: var(--text-base);
    color: var(--color-text-mute);
    margin-block-end: var(--space-1);
  }
  .watch-list {
    margin: 0;
    padding-inline-start: var(--space-4);
    display: grid;
    gap: 0.25rem;
    color: var(--color-text-mute);
    font-size: var(--text-sm);
  }
  .watch-list strong { color: var(--color-text); }

  code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-surface-2);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
  }
</style>
