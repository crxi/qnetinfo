---
/**
 * /companies — Vendor landscape (landing page)
 *
 * Tier E · Applications & market.
 *
 * The landing reads every YAML in qnetinfo/companies/ via the companies
 * loader and groups vendors by primary category. The textual platform
 * lists below (transmon / trapped-ion / etc.) survive as a static
 * snapshot for vendors that don't have a dossier yet — once a dossier
 * lands in qnetinfo/companies/<slug>.yaml, the vendor's name on this
 * landing page can be promoted to a link to its sub-page.
 *
 * Citations:
 *   - ezratty-uqt-2025-p2 — survey-level coverage of the vendor landscape.
 *   - meddeb-comnet-2025 — per-platform R&D status.
 *   - kumar-ijndc-2025 — survey-level positioning.
 */
import Infographic from "../layouts/Infographic.astro";
import Center from "../components/Center.astro";
import Stack from "../components/Stack.astro";
import SiteNav from "../components/SiteNav.astro";
import SourceNote from "../components/SourceNote.astro";
import CompanyLogo from "../components/CompanyLogo.astro";
import {
  COMPANIES,
  CATEGORY_LABEL,
  CATEGORY_ORDER,
  companiesByPrimary,
  type Company,
} from "../lib/companies.ts";

const sections = [
  { id: "overview",   label: "Overview" },
  { id: "dossiers",   label: "Vendor dossiers" },
  { id: "computers",  label: "Computer vendors" },
  { id: "networking", label: "Networking & QKD" },
  { id: "components", label: "Components" },
  { id: "notes",      label: "Notes on this page" },
];

// Group dossiers by primary category, in the canonical CATEGORY_ORDER.
const grouped: { category: typeof CATEGORY_ORDER[number]; companies: Company[] }[] =
  CATEGORY_ORDER
    .map((c) => ({ category: c, companies: companiesByPrimary(c) }))
    .filter((g) => g.companies.length > 0);

const haveDossiers = COMPANIES.length > 0;
---

<Infographic
  title="Companies — vendor landscape"
  description="A growing index of vendors building quantum-network hardware and applications. Vendors with a YAML dossier render as deep-dive sub-pages with milestones, roadmap, and capability metrics."
  references={[
    "ezratty-uqt-2025-p2",
    "kumar-ijndc-2025",
    "meddeb-comnet-2025",
  ]}
>
  <SiteNav slot="nav" currentSubject="companies" sections={sections} />

  <Center max="var(--wide-width)" gutter="var(--space-3)">
    <Stack space="var(--space-6)">

      <header class="hero" id="overview" data-nav-section>
        <h1>Companies — vendor landscape</h1>
        <p>
          A quantum-networking workspace that doesn't track vendors loses touch with what
          can actually be procured. This page has two layers: a deep-dive dossier per
          vendor — milestones, roadmap, capability metrics, all cited to primary sources
          — and a static landscape snapshot for vendors where the dossier hasn't been
          written yet <SourceNote id="ezratty-uqt-2025-p2" /><SourceNote id="meddeb-comnet-2025" />.
        </p>
        <p>
          Vendors split naturally into three buckets: <strong>computers</strong> (build
          quantum processors), <strong>networking &amp; QKD</strong> (build the network
          fabric or the QKD endpoints), and <strong>components</strong> (build the
          memories, sources, and other infrastructure that the other two consume).
        </p>
      </header>

      <section id="dossiers" data-nav-section>
        <h2>Vendor dossiers</h2>
        {haveDossiers ? (
          <p>
            Each dossier below links to a per-vendor page with milestones, roadmap, and
            modality-specific capability details. Compiled from primary sources (papers,
            vendor technology pages); see each page for source links.
          </p>
        ) : (
          <p class="empty">No dossiers compiled yet.</p>
        )}
        {grouped.map((group) => (
          <div class="dossier-group">
            <h3 class="dossier-group-title">{CATEGORY_LABEL[group.category]}</h3>
            <ul class="dossier-grid">
              {group.companies.map((c) => (
                <li class="dossier-card">
                  <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/companies/${c.slug}`}>
                    <div class="dossier-head">
                      <CompanyLogo name={c.name} logo={c.logo} size={32} />
                      <div class="dossier-name">{c.name}</div>
                    </div>
                    <div class="dossier-positioning">{c.positioning}</div>
                    <div class="dossier-meta">
                      {c.categories.length > 1 && (
                        <span class="dossier-extra-cats">
                          also: {c.categories.slice(1).map((cc) => CATEGORY_LABEL[cc]).join(", ")}
                        </span>
                      )}
                      <span class="dossier-hq">{c.hq}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <section id="computers" data-nav-section>
        <h2>Computer vendors (landscape snapshot)</h2>
        <p>
          Vendors building quantum processors. The platform column maps onto the
          stationary-qubit encodings covered in the qubits subject. Names without
          a dossier yet appear as plain text.
        </p>

        <h3 class="vendor-platform">Superconducting</h3>
        <ul class="vendor-list">
          <li><strong>Google</strong> — transmon; Sycamore lineage.</li>
          <li><strong>IBM</strong> — transmon; large public roadmap (Heron, Nighthawk, Starling, Blue Jay).</li>
          <li><strong>IQM</strong> — transmon; multi-chip systems.</li>
          <li><strong>Rigetti</strong> — transmon; Ankaa series.</li>
          <li><strong>USTC</strong> — transmon; Jiuzhang and Zuchongzhi families.</li>
        </ul>

        <h3 class="vendor-platform">Trapped ion</h3>
        <ul class="vendor-list">
          <li><strong>AQT (Alpine Quantum Technologies)</strong> — Ca⁺ / Yb⁺; rack-mounted ion-trap systems.</li>
          <li><strong>IonQ</strong> — Yb⁺ / Ba⁺; commercial cloud access.</li>
          <li><strong>Oxford Ionics</strong> — Sr⁺; on-chip integration.</li>
          <li><strong>Quantinuum</strong> — Yb⁺ / Ba⁺; H1/H2 racetrack QCCD systems.</li>
          <li><strong>Universal Quantum</strong> — Yb⁺ networked-ion modules.</li>
        </ul>

        <h3 class="vendor-platform">Neutral atom</h3>
        <ul class="vendor-list">
          <li><strong>Atom Computing</strong> — Sr; large-array room-temperature systems.</li>
          <li><strong>ColdQuanta / Infleqtion</strong> — Rb; computing + sensing.</li>
          <li><strong>Pasqal</strong> — Rb; Orion line, analog and digital modes.</li>
          <li><strong>QuEra</strong> — Rb-87; Rydberg gates on optical tweezer arrays.</li>
        </ul>

        <h3 class="vendor-platform">Photonic</h3>
        <ul class="vendor-list">
          <li><strong>ORCA Computing</strong> — photonic memory-based; squeezed-light approach.</li>
          <li><strong>PsiQuantum</strong> — photonic fault-tolerant; silicon-photonic chips.</li>
          <li><strong>Quandela</strong> — quantum-dot single-photon sources + photonic chips.</li>
          <li><strong>QuiX Quantum</strong> — photonic linear-optical processors.</li>
          <li><strong>Xanadu</strong> — photonic, continuous-variable + Gaussian boson sampling.</li>
        </ul>

        <h3 class="vendor-platform">NV / SiV (diamond)</h3>
        <ul class="vendor-list">
          <li><strong>Lightsynq</strong> — SiV-centre memory nodes for the quantum internet.</li>
          <li><strong>Quantum Brilliance</strong> — NV-centre room-temperature compute appliances.</li>
        </ul>

        <h3 class="vendor-platform">Topological (Majorana)</h3>
        <ul class="vendor-list">
          <li><strong>Microsoft</strong> — Majorana-zero-mode qubits in InAs / Al hybrid devices; long-running topological-qubit programme.</li>
        </ul>
      </section>

      <section id="networking" data-nav-section>
        <h2>Networking and QKD vendors</h2>
        <p>
          Vendors building the network fabric or the QKD endpoint systems that consume it.
        </p>

        <ul class="vendor-list">
          <li><strong>Aliro Quantum</strong> — quantum-network orchestration and simulation; AliroNet stack.</li>
          <li><strong>ID Quantique</strong> — QKD systems; long-running commercial deployment.</li>
          <li><strong>MagiQ Technologies</strong> — QKD endpoints.</li>
          <li><strong>Quantum Bridge Tech</strong> — quantum-network infrastructure for QKD and entanglement distribution.</li>
          <li><strong>Qunnect</strong> — quantum-networking testbed hardware; Rb-vapour memories.</li>
          <li><strong>Toshiba</strong> — QKD systems; Twin-Field demonstrations.</li>
        </ul>
      </section>

      <section id="components" data-nav-section>
        <h2>Components</h2>
        <p>
          Vendors building memories, photon sources, transducers, and other components
          that the computer and networking layers consume.
        </p>

        <h3 class="vendor-platform">Quantum memory</h3>
        <ul class="vendor-list">
          <li><strong>Lightsynq</strong> — SiV-centre quantum-memory modules.</li>
          <li><strong>memQ</strong> — Er³⁺-doped telecom-band quantum memories (Argonne / Awschalom-group spin-out).</li>
          <li><strong>Qunnect</strong> — Rb-vapour quantum memories (also networking, above).</li>
          <li><strong>Welinq</strong> — QDrive Rb cold-atom memory module.</li>
        </ul>

        <h3 class="vendor-platform">Single-photon sources</h3>
        <ul class="vendor-list">
          <li><strong>Aegiq</strong> — quantum-dot single-photon source components.</li>
          <li><strong>Quandela</strong> — quantum-dot single-photon sources + photonic chips (also photonic computers, above).</li>
          <li><strong>Sparrow Quantum</strong> — quantum-dot single-photon source devices.</li>
        </ul>

        <h3 class="vendor-platform">Photonic processors and integration</h3>
        <ul class="vendor-list">
          <li><strong>QuiX Quantum</strong> — photonic processors and integrated circuits (also photonic computers, above).</li>
        </ul>

        <h3 class="vendor-platform">Materials and foundry</h3>
        <ul class="vendor-list">
          <li><strong>Element Six</strong> — synthetic-diamond foundry; substrates for NV / SiV memory nodes.</li>
        </ul>
      </section>

      <section id="notes" data-nav-section>
        <h2>Notes on this page</h2>
        <ul>
          <li>
            <strong>The landscape snapshot is a starting point.</strong> Names + platforms
            + one-line positions, drawn from survey literature. Goes stale within months.
          </li>
          <li>
            <strong>Dossiers are the long-term tracking surface.</strong> Milestones,
            roadmap, capability metrics, and citations. Fields the dossier couldn't
            verify to a primary source are shown as <em>unverified</em> rather than
            filled in with a guess.
          </li>
          <li>
            <strong>Source priority for dossiers:</strong> peer-reviewed paper &gt; arXiv
            preprint &gt; vendor blog or technology page &gt; press release &gt; industry
            tracker. Wikipedia is acceptable only for company-history facts, never for
            technical numbers.
          </li>
          <li>
            <strong>Staleness.</strong> Each dossier records when it was last verified.
            Entries older than three months get a <em>stale</em> badge on the dossier
            page — a prompt to re-check the primary sources.
          </li>
        </ul>
        <p>
          For survey-level reference on the per-platform vendor landscape, see Ezratty
          UQT Pt 2 <SourceNote id="ezratty-uqt-2025-p2" /> and Kumar 2025
          IJNDC <SourceNote id="kumar-ijndc-2025" />.
        </p>
      </section>

    </Stack>
  </Center>
</Infographic>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-4);
    display: grid;
    gap: var(--space-3);
  }
  .hero h1 { margin: 0; }
  .hero p { margin: 0; }

  section { display: grid; gap: var(--space-3); }
  section h3.vendor-platform {
    margin: 0;
    margin-block-start: var(--space-2);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  ul {
    margin: 0;
    padding-inline-start: var(--space-4);
    display: grid;
    gap: var(--space-2);
  }
  li { line-height: var(--leading-snug); }

  .vendor-list li { color: var(--color-text-mute); }
  .vendor-list strong { color: var(--color-text); }

  /* Dossier grid */
  .dossier-group { display: grid; gap: var(--space-2); margin-block-end: var(--space-3); }
  .dossier-group-title {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text);
  }
  .dossier-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(340px, 100%), 1fr));
    max-inline-size: min(100%, 1100px);
    gap: var(--space-2);
  }
  .dossier-card {
    padding: 0;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    transition: border-color 150ms ease;
  }
  .dossier-card:hover { border-color: var(--color-accent); }
  .dossier-card a {
    display: grid;
    gap: 6px;
    padding: var(--space-3);
    color: inherit;
    text-decoration: none;
  }
  .dossier-head {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .dossier-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--text-md);
  }
  .dossier-positioning {
    font-size: var(--text-sm);
    color: var(--color-text-mute);
    line-height: var(--leading-snug);
  }
  .dossier-meta {
    margin-block-start: var(--space-1);
    display: flex; gap: var(--space-2); flex-wrap: wrap;
    font-size: var(--text-xs); color: var(--color-text-mute);
  }
  .dossier-extra-cats { color: var(--color-accent); }
  .empty { color: var(--color-text-mute); }

  code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-surface-2);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
  }
</style>
