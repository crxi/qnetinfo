    gap: var(--space-2);
  }
  li { line-height: var(--leading-snug); }

  /* Architecture cards inside the Grid component. align-content: start
     pins each card's content to the top so a longer sibling doesn't
     stretch its neighbours' h3 to a different baseline. */
  .arch-card {
    display: grid;
    align-content: start;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
  }
  .arch-card h3 {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text);
  }
  .arch-card p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-text-mute);
  }

  /* Schematic figure: the three-row architecture comparison. */
  .arch-fig {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    display: grid;
    gap: var(--space-3);
  }
  .arch-fig svg {
    inline-size: 100%;
    block-size: auto;
    display: block;
  }
  /* Below 36rem the row is too wide for legibility at 360px viewport.
     The SVG sits in a scroll wrapper with min-width so labels stay
     readable; the figcaption stays in normal flow. */
