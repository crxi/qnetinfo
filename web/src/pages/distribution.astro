  @media (max-width: 36rem) {
    .arch-fig-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .arch-fig svg {
      min-inline-size: 600px;
    }
  }
  .arch-fig figcaption {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-text-mute);
  }

  /* :global() because Astro scoped CSS doesn't propagate to <text>
     children in inline SVG. */
  :global(.arch-row-label) {
    font-size: 13px;
    font-weight: 700;
    fill: var(--color-text);
    font-family: var(--font-mono);
  }
  :global(.arch-node-label) {
    font-size: 10px;
    fill: var(--color-text-mute);
