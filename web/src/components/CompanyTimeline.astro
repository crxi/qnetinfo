---
/**
 * Horizontal timeline. A single time axis runs across the figure with
 * year ticks and a "today" marker; each event sits on the axis as a
 * dot, and a connector arrow points to a card off the axis with the
 * date and headline. Cards stagger above/below (two levels each side)
 * so adjacent events don't collide, and they hold a real line-and-a-
 * half of text instead of the old SVG-text 22-character truncation.
 *
 * Past events = filled accent dot + tinted card.
 * Future (roadmap) events = outlined dot + dashed-border card.
 *
 * Pure SVG, no JS. HTML rendering inside the SVG uses foreignObject
 * so the card text wraps naturally.
 */
import type { Milestone, RoadmapItem } from "../lib/companies.ts";
import { formatDateLabel } from "../lib/companies.ts";

interface Props {
  milestones: Milestone[];
  roadmap: RoadmapItem[];
  foundedYear: number;
}

const { milestones, roadmap, foundedYear } = Astro.props;

// --- Date parsing ----------------------------------------------------------
function parseFracYear(input: string | number | Date): number {
  if (input instanceof Date) {
    return input.getUTCFullYear() + input.getUTCMonth() / 12;
  }
  const s = String(input).trim();
  const q = s.match(/^Q([1-4])\s+(\d{4})$/i);
  if (q) return parseInt(q[2], 10) + (parseInt(q[1], 10) - 1) * 0.25;
  const parts = s.split("-").map((n) => parseInt(n, 10));
  return parts[0] + ((parts[1] ?? 6) - 1) / 12;
}

const nowFrac = (() => {
  const d = new Date();
  return d.getUTCFullYear() + d.getUTCMonth() / 12;
})();

type Point = {
  fracYear: number;
  dateLabel: string;
  label: string;
  kind: "milestone" | "roadmap";
};

const points: Point[] = [
  ...milestones.map((m) => ({
    fracYear: parseFracYear(m.date),
    dateLabel: formatDateLabel(m.date),
    label: m.headline,
    kind: "milestone" as const,
  })),
  ...roadmap.map((r) => ({
    fracYear: parseFracYear(r.target),
    dateLabel: formatDateLabel(r.target),
    label: r.item,
    kind: "roadmap" as const,
  })),
].sort((a, b) => a.fracYear - b.fracYear);

const hasContent = points.length > 0;

// --- Canvas geometry -------------------------------------------------------
// Anchor to events, not founding year, so vendors with deep histories
// (IBM 1911, Cisco 1984) don't stretch the axis over a century.
const itemFracs = points.map((p) => p.fracYear);
const earliest = itemFracs.length ? Math.min(...itemFracs) : nowFrac - 3;
const latest = itemFracs.length ? Math.max(...itemFracs) : nowFrac + 2;
const yearStart = Math.floor(Math.min(earliest, nowFrac - 2));
const yearEnd = Math.ceil(Math.max(latest, nowFrac + 2));

const W = 980;
const PAD_L = 40;
const PAD_R = 40;
const AXIS_Y = 260;
const AXIS_W = W - PAD_L - PAD_R;

const BOX_W = 170;
const BOX_H = 78;
// Vertical placement of card *top edge* for each stagger level.
const LEVEL_Y = [
  AXIS_Y - 60 - BOX_H, // above near (card just above axis)
  AXIS_Y + 60,         // below near
  AXIS_Y - 180 - BOX_H, // ABOVE FAR was unused if too tall; use moderate
  AXIS_Y + 180,        // below far
];
// Trim: with these constants the SVG needs H ≈ above_far_top + room → recompute.
const SVG_TOP = Math.min(...LEVEL_Y) - 8;
const SVG_BOTTOM = Math.max(LEVEL_Y[1] + BOX_H, LEVEL_Y[3] + BOX_H) + 28;
const H = SVG_BOTTOM - SVG_TOP;

function xForYear(y: number): number {
  return PAD_L + ((y - yearStart) / (yearEnd - yearStart)) * AXIS_W;
}

const yearTicks: number[] = [];
for (let y = yearStart; y <= yearEnd; y++) yearTicks.push(y);

// Clamp card x so the box never spills off the SVG horizontally.
function clampBoxLeft(centerX: number): number {
  const halfW = BOX_W / 2;
  return Math.max(PAD_L - 4, Math.min(W - PAD_R + 4 - BOX_W, centerX - halfW));
}

// Stagger pattern: above-near, below-near, above-near, below-near, ...
// For runs longer than 2 in a row at the same level, push to the far slot.
type Placed = Point & {
  x: number;
  boxLeft: number;
  boxTop: number;
  above: boolean;
};
const placements: Placed[] = [];
for (const p of points) {
  const x = xForYear(p.fracYear);
  // Try levels in priority order, alternating which side we hit first
  // so consecutive items don't pile up on the same side of the axis.
  const order = [0, 1, 2, 3];
  const startIdx = placements.length % 2;
  const tryOrder = [...order.slice(startIdx), ...order.slice(0, startIdx)];
  let chosen = tryOrder[0];
  for (const lvl of tryOrder) {
    chosen = lvl;
    const conflict = placements.some((q) => {
      if (q.boxTop !== LEVEL_Y[lvl]) return false;
      return Math.abs(q.x - x) < BOX_W + 8;
    });
    if (!conflict) break;
  }
  const boxTop = LEVEL_Y[chosen];
  placements.push({
    ...p,
    x,
    boxLeft: clampBoxLeft(x),
    boxTop,
    above: boxTop < AXIS_Y,
  });
}
---

{hasContent ? (
  <figure class="ct">
    <div class="ct-scroll">
      <svg
        viewBox={`0 ${SVG_TOP} ${W} ${H}`}
        role="img"
        aria-label="Vendor timeline of past milestones and public roadmap"
      >
        {/* Past portion of axis */}
        <line
          x1={PAD_L}
          y1={AXIS_Y}
          x2={xForYear(nowFrac)}
          y2={AXIS_Y}
          class="ct-axis ct-axis--past"
        />
        {/* Future portion */}
        <line
          x1={xForYear(nowFrac)}
          y1={AXIS_Y}
          x2={W - PAD_R}
          y2={AXIS_Y}
          class="ct-axis ct-axis--future"
        />

        {/* Year ticks */}
        {yearTicks.map((y) => (
          <g>
            <line
              x1={xForYear(y)}
              y1={AXIS_Y - 4}
              x2={xForYear(y)}
              y2={AXIS_Y + 4}
              class="ct-tick"
            />
            <text x={xForYear(y)} y={AXIS_Y + 20} class="ct-year">{y}</text>
          </g>
        ))}

        {/* 'Today' marker */}
        <line
          x1={xForYear(nowFrac)}
          y1={SVG_TOP + 4}
          x2={xForYear(nowFrac)}
          y2={SVG_BOTTOM - 22}
          class="ct-today"
        />
        <text
          x={xForYear(nowFrac)}
          y={SVG_BOTTOM - 6}
          class="ct-today-label"
        >today</text>

        {/* Events: connector + dot + card */}
        {placements.map((p) => {
          const connTop = p.above ? p.boxTop + BOX_H : AXIS_Y;
          const connBot = p.above ? AXIS_Y : p.boxTop;
          return (
            <g class={`ct-event ct-event--${p.kind}`}>
              <line
                x1={p.x}
                y1={connTop}
                x2={p.x}
                y2={connBot}
                class="ct-connector"
              />
              {p.kind === "milestone" ? (
                <circle cx={p.x} cy={AXIS_Y} r="5.5" class="ct-dot ct-dot--past" />
              ) : (
                <circle cx={p.x} cy={AXIS_Y} r="5.5" class="ct-dot ct-dot--future" />
              )}
              <foreignObject
                x={p.boxLeft}
                y={p.boxTop}
                width={BOX_W}
                height={BOX_H}
              >
                <div
                  xmlns="http://www.w3.org/1999/xhtml"
                  class={`ct-card ct-card--${p.kind}`}
                  title={`${p.dateLabel} — ${p.label}`}
                >
                  <div class="ct-card-date">{p.dateLabel}</div>
                  <div class="ct-card-headline">{p.label}</div>
                </div>
              </foreignObject>
            </g>
          );
        })}
      </svg>
    </div>
    <figcaption>
      {foundedYear < yearStart && (
        <span class="ct-legend ct-legend--founded">
          Founded {foundedYear}
        </span>
      )}
      <span class="ct-legend">
        <span class="ct-legend-dot ct-legend-dot--past" aria-hidden="true"></span>
        shipped milestone
      </span>
      <span class="ct-legend">
        <span class="ct-legend-dot ct-legend-dot--future" aria-hidden="true"></span>
        public roadmap
      </span>
    </figcaption>
  </figure>
) : (
  <p class="empty">No timeline data — add milestones or roadmap entries.</p>
)}

<style>
  .ct {
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }
  .ct-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .ct svg {
    inline-size: 100%;
    block-size: auto;
    display: block;
  }
  @media (max-width: 64rem) {
    .ct svg { min-inline-size: 900px; }
  }

  /* Axis */
  :global(.ct-axis) { stroke-width: 2; fill: none; }
  :global(.ct-axis--past) { stroke: var(--color-accent); }
  :global(.ct-axis--future) {
    stroke: var(--color-text-soft);
    stroke-dasharray: 4 3;
    opacity: 0.7;
  }
  :global(.ct-tick) {
    stroke: var(--color-text-soft);
    stroke-width: 1;
  }
  :global(.ct-year) {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--color-text-mute);
    text-anchor: middle;
  }
  :global(.ct-today) {
    stroke: var(--color-accent-2);
    stroke-width: 1.4;
    stroke-dasharray: 3 3;
  }
  :global(.ct-today-label) {
    fill: var(--color-accent-2);
    font-size: 10.5px;
    font-style: italic;
    text-anchor: middle;
  }

  /* Dots on the axis */
  :global(.ct-dot) {
    stroke: var(--color-bg);
    stroke-width: 1.5;
  }
  :global(.ct-dot--past) { fill: var(--color-accent); }
  :global(.ct-dot--future) {
    fill: var(--color-bg);
    stroke: var(--color-accent);
    stroke-width: 2;
  }

  /* Connectors (arrows) */
  :global(.ct-connector) {
    stroke: var(--color-text-soft);
    stroke-width: 1;
  }
  :global(.ct-event--milestone .ct-connector) {
    stroke: color-mix(in srgb, var(--color-accent) 60%, var(--color-text-soft));
  }
  :global(.ct-event--roadmap .ct-connector) {
    stroke: color-mix(in srgb, var(--color-accent) 50%, var(--color-text-soft));
    stroke-dasharray: 3 2;
  }

  /* Cards (foreignObject content) */
  :global(.ct-card) {
    box-sizing: border-box;
    block-size: 100%;
    padding: 6px 8px 7px;
    border: 1px solid var(--card-border);
    border-radius: 5px;
    background: var(--card-bg);
    display: grid;
    gap: 3px;
    align-content: start;
    font-family: var(--font-sans, system-ui);
  }
  :global(.ct-card--milestone) {
    background: color-mix(in srgb, var(--color-accent) 9%, var(--card-bg));
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--card-border));
  }
  :global(.ct-card--roadmap) {
    background: var(--card-bg);
    border-style: dashed;
    border-color: var(--color-accent);
  }
  :global(.ct-card:hover) {
    border-color: var(--color-accent);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-accent) 50%, transparent);
  }
  :global(.ct-card-date) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-mute);
    letter-spacing: 0.04em;
  }
  :global(.ct-card-headline) {
    font-size: 11px;
    line-height: 1.32;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Legend */
  .ct figcaption {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    font-size: var(--text-xs);
    color: var(--color-text-mute);
  }
  .ct-legend { display: inline-flex; align-items: center; gap: 6px; }
  .ct-legend--founded {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
  }
  .ct-legend-dot {
    inline-size: 10px;
    block-size: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .ct-legend-dot--past { background: var(--color-accent); }
  .ct-legend-dot--future {
    background: transparent;
    border: 2px solid var(--color-accent);
    box-sizing: border-box;
  }
  .empty { color: var(--color-text-mute); }
</style>
