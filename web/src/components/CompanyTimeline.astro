---
/**
 * Horizontal timeline combining past milestones and forward roadmap.
 * Year ticks on the axis, a vertical 'today' marker, and labelled
 * dots — past = filled, future = outline. Labels use a 4-level
 * vertical stagger (above-far / below-near / above-near / below-far)
 * so adjacent items don't collide, and wrap to 2 lines instead of
 * truncating with ellipsis.
 *
 * Pure SVG, no JS.
 */
import type { Milestone, RoadmapItem } from "../lib/companies.ts";

interface Props {
  milestones: Milestone[];
  roadmap: RoadmapItem[];
  foundedYear: number;
}

const { milestones, roadmap, foundedYear } = Astro.props;

/** Parse "2024-09", "Q3 2024", or 2024 (number) into a fractional year. */
function parseToFracYear(input: string | number | Date): number {
  if (input instanceof Date) return input.getFullYear() + input.getMonth() / 12;
  const s = String(input).trim();
  const qMatch = s.match(/^Q([1-4])\s+(\d{4})$/i);
  if (qMatch) {
    return parseInt(qMatch[2], 10) + (parseInt(qMatch[1], 10) - 1) * 0.25;
  }
  const parts = s.split("-").map((n) => parseInt(n, 10));
  return parts[0] + ((parts[1] ?? 6) - 1) / 12;
}

type Point = {
  fracYear: number;
  label: string;
  kind: "milestone" | "roadmap";
};

const nowFrac = (() => {
  const d = new Date();
  return d.getFullYear() + d.getMonth() / 12;
})();

const points: Point[] = [
  ...milestones.map((m) => ({
    fracYear: parseToFracYear(m.date),
    label: m.headline,
    kind: "milestone" as const,
  })),
  ...roadmap.map((r) => ({
    fracYear: parseToFracYear(r.target),
    label: r.item,
    kind: "roadmap" as const,
  })),
].sort((a, b) => a.fracYear - b.fracYear);

const hasContent = points.length > 0;

let yearStart = foundedYear;
let yearEnd = Math.ceil(nowFrac) + 2;
if (hasContent) {
  yearStart = Math.min(yearStart, Math.floor(points[0].fracYear));
  yearEnd = Math.max(yearEnd, Math.ceil(points[points.length - 1].fracYear) + 1);
}

const W = 880;
const H = 280;
const PAD_L = 30;
const PAD_R = 30;
const AXIS_Y = 140;
const AXIS_W = W - PAD_L - PAD_R;

function xForYear(y: number): number {
  return PAD_L + ((y - yearStart) / (yearEnd - yearStart)) * AXIS_W;
}

const yearTicks: number[] = [];
for (let y = yearStart; y <= yearEnd; y++) yearTicks.push(y);

/** Word-wrap into at most 2 lines, ~22 chars per line. Final line gets
 *  '…' if the headline is longer than the 2-line budget. */
function wrap(text: string, maxLen = 24): [string, string] {
  if (text.length <= maxLen) return [text, ""];
  let cut = text.lastIndexOf(" ", maxLen);
  if (cut < maxLen * 0.5) cut = maxLen; // forced cut on a long word
  const line1 = text.slice(0, cut);
  let line2 = text.slice(cut).trim();
  const maxLine2 = Math.round(maxLen * 1.4);
  if (line2.length > maxLine2) line2 = line2.slice(0, maxLine2 - 1).trimEnd() + "…";
  return [line1, line2];
}

/** 4-level stagger. Returns the y-coords for the connector-line top
 *  and label baseline; line1 sits at labelY, line2 1.1em below. */
type Placement = { lineYEnd: number; labelY: number; above: boolean };
function placement(i: number): Placement {
  const level = i % 4;
  if (level === 0) return { lineYEnd: AXIS_Y - 74, labelY: AXIS_Y - 80, above: true };
  if (level === 1) return { lineYEnd: AXIS_Y + 30, labelY: AXIS_Y + 42, above: false };
  if (level === 2) return { lineYEnd: AXIS_Y - 34, labelY: AXIS_Y - 40, above: true };
  return /* level 3 */ { lineYEnd: AXIS_Y + 68, labelY: AXIS_Y + 82, above: false };
}
---

{hasContent ? (
  <figure class="ct">
    <div class="ct-scroll">
    <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Company milestone and roadmap timeline">
      {/* Past/future axis band shading */}
      <rect x={PAD_L} y={AXIS_Y - 1} width={xForYear(nowFrac) - PAD_L} height={2}
            fill="var(--color-accent)"/>
      <rect x={xForYear(nowFrac)} y={AXIS_Y - 1} width={W - PAD_R - xForYear(nowFrac)} height={2}
            fill="var(--color-text-soft)" opacity="0.4"/>

      {/* Year ticks */}
      {yearTicks.map((y) => (
        <g>
          <line x1={xForYear(y)} y1={AXIS_Y - 4} x2={xForYear(y)} y2={AXIS_Y + 4}
                stroke="var(--color-text-soft)" stroke-width="1"/>
          <text x={xForYear(y)} y={AXIS_Y + 18} text-anchor="middle" class="ct-year">{y}</text>
        </g>
      ))}

      {/* 'Today' vertical line */}
      <line x1={xForYear(nowFrac)} y1={20} x2={xForYear(nowFrac)} y2={H - 20}
            stroke="var(--color-accent-2)" stroke-width="1.2" stroke-dasharray="3,3"/>
      <text x={xForYear(nowFrac)} y={H - 6} text-anchor="middle" class="ct-now">today</text>

      {/* Points */}
      {points.map((p, i) => {
        const x = xForYear(p.fracYear);
        const place = placement(i);
        const [line1, line2] = wrap(p.label, 24);
        return (
          <g>
            <line x1={x} y1={AXIS_Y} x2={x} y2={place.lineYEnd}
                  stroke="var(--color-text-soft)" stroke-width="0.8"/>
            {p.kind === "milestone" ? (
              <circle cx={x} cy={AXIS_Y} r="5" fill="var(--color-accent)" stroke="var(--color-bg)" stroke-width="1.5"/>
            ) : (
              <circle cx={x} cy={AXIS_Y} r="5" fill="var(--color-bg)" stroke="var(--color-accent)" stroke-width="2"/>
            )}
            <text x={x} y={place.labelY} text-anchor="middle" class="ct-label">
              <tspan x={x}>{line1}</tspan>
              {line2 && <tspan x={x} dy="1.1em">{line2}</tspan>}
            </text>
          </g>
        );
      })}
    </svg>
    </div>
    <figcaption>
      <span class="ct-legend"><span class="ct-dot ct-dot--past"></span> shipped milestone</span>
      <span class="ct-legend"><span class="ct-dot ct-dot--future"></span> public roadmap</span>
    </figcaption>
  </figure>
) : (
  <p class="empty">No timeline data — add milestones or roadmap entries.</p>
)}

<style>
  .ct { margin: 0; display: grid; gap: var(--space-2); }
  /* The SVG fills the container on desktop. At phone width the viewBox
     (880×280) would scale to ~25% and the hardcoded 10px text would
     become unreadable (~3-4px effective). Below 36rem the SVG wrapper
     gets horizontal scroll with a min-width so the user pans the
     timeline at legible size. Figcaption stays in normal flow. */
  .ct-scroll { inline-size: 100%; }
  .ct svg { inline-size: 100%; block-size: auto; display: block; }
  @media (max-width: 36rem) {
    .ct-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .ct svg { min-inline-size: 720px; }
  }
  :global(.ct-year) {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-text-mute);
  }
  :global(.ct-now) {
    font-size: 10px;
    fill: var(--color-accent-2);
    font-style: italic;
  }
  :global(.ct-label) {
    font-size: 10.5px;
    fill: var(--color-text);
  }
  .ct figcaption {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-mute);
  }
  .ct-legend { display: inline-flex; align-items: center; gap: 6px; }
  .ct-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .ct-dot--past   { background: var(--color-accent); }
  .ct-dot--future { background: var(--color-bg); border: 2px solid var(--color-accent); }
  .empty { color: var(--color-text-mute); }
</style>
