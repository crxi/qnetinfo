---
/**
 * Year-cell timeline. One box per year between the first event and
 * two years past today. Cells with events "light up"; events stack
 * vertically inside the cell, so a dense year (e.g. IBM 2025) reads
 * as a list, not a pile of colliding axis dots.
 *
 * Past = filled, current year = highlighted, future = dashed outline.
 * Pure HTML/CSS — no SVG, no JS.
 */
import type { Milestone, RoadmapItem } from "../lib/companies.ts";
import { formatDateLabel } from "../lib/companies.ts";

interface Props {
  milestones: Milestone[];
  roadmap: RoadmapItem[];
  foundedYear: number;
}

const { milestones, roadmap, foundedYear } = Astro.props;

const nowYear = new Date().getFullYear();

type CellItem = {
  label: string;
  kind: "milestone" | "roadmap";
  date: string;
};

function parseYear(input: string | number): number {
  if (typeof input === "number") return input;
  const s = String(input).trim();
  const qm = s.match(/^Q([1-4])\s+(\d{4})$/i);
  if (qm) return parseInt(qm[2], 10);
  return parseInt(s.split("-")[0], 10);
}

const items: CellItem[] = [
  ...milestones.map((m) => ({
    label: m.headline,
    kind: "milestone" as const,
    date: formatDateLabel(m.date),
  })),
  ...roadmap.map((r) => ({
    label: r.item,
    kind: "roadmap" as const,
    date: formatDateLabel(r.target),
  })),
];

// Anchor the timeline to the events, not to foundedYear — IBM (1911) or
// Cisco (1984) would otherwise produce a 100-cell-wide strip with one
// lit cell. Founded year is shown in the dossier header.
const itemYears = items.map((i) => parseYear(i.date));
const earliestItem = itemYears.length ? Math.min(...itemYears) : nowYear - 5;
const latestItem = itemYears.length ? Math.max(...itemYears) : nowYear + 2;
const yearStart = Math.min(earliestItem, nowYear - 3);
const yearEnd = Math.max(latestItem, nowYear + 2);

const years: number[] = [];
for (let y = yearStart; y <= yearEnd; y++) years.push(y);

const byYear = new Map<number, CellItem[]>();
for (const it of items) {
  const y = parseYear(it.date);
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(it);
}
for (const [, arr] of byYear) arr.sort((a, b) => a.date.localeCompare(b.date));

const hasContent = items.length > 0;
const showFoundedTag = foundedYear < yearStart;
---

{hasContent ? (
  <figure class="ct">
    {showFoundedTag && (
      <p class="ct-founded">
        <span class="ct-founded-label">Founded</span> {foundedYear}
        <span class="ct-founded-gap"> · timeline starts at first public milestone</span>
      </p>
    )}
    <div class="ct-scroll">
      <ol class="ct-row" role="list">
        {years.map((y) => {
          const cellItems = byYear.get(y) ?? [];
          const lit = cellItems.length > 0;
          const isPast = y < nowYear;
          const isNow = y === nowYear;
          const isFuture = y > nowYear;
          const cls = ["ct-cell"];
          if (lit) cls.push("is-lit");
          if (isPast) cls.push("is-past");
          if (isNow) cls.push("is-now");
          if (isFuture) cls.push("is-future");
          return (
            <li class={cls.join(" ")}>
              <div class="ct-year-label">{y}</div>
              {cellItems.length > 0 && (
                <ul class="ct-items" role="list">
                  {cellItems.map((it) => (
                    <li
                      class={`ct-item ct-item--${it.kind}`}
                      title={`${it.date} — ${it.label}`}
                    >
                      <span class="ct-dot" aria-hidden="true"></span>
                      <span class="ct-text">{it.label}</span>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ol>
    </div>
    <figcaption>
      <span class="ct-legend">
        <span class="ct-legend-dot ct-legend-dot--past"></span>
        shipped milestone
      </span>
      <span class="ct-legend">
        <span class="ct-legend-dot ct-legend-dot--future"></span>
        public roadmap
      </span>
      <span class="ct-legend ct-legend--now">
        <span class="ct-legend-now-box"></span>
        current year ({nowYear})
      </span>
    </figcaption>
  </figure>
) : (
  <p class="empty">No timeline data — add milestones or roadmap entries.</p>
)}

<style>
  .ct {
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }
  .ct-founded {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-mute);
  }
  .ct-founded-label {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    margin-inline-end: 4px;
  }
  .ct-founded-gap { opacity: 0.7; }

  /* Horizontal scroll on narrow viewports; cells keep a minimum width
     so the year labels and item text stay legible. */
  .ct-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .ct-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(96px, 1fr);
    gap: 4px;
  }

  /* Cell */
  .ct-cell {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 6px;
    padding: 8px 7px 9px;
    border: 1px solid var(--card-border);
    border-radius: 5px;
    background: transparent;
    min-block-size: 96px;
    transition: border-color 120ms ease, background 120ms ease;
  }
  /* Lit past cells: filled with the accent tint */
  .ct-cell.is-lit.is-past {
    background: color-mix(in srgb, var(--color-accent) 9%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--card-border));
  }
  /* Lit current-year cell: highlighted */
  .ct-cell.is-lit.is-now {
    background: color-mix(in srgb, var(--color-accent-2) 14%, transparent);
    border-color: var(--color-accent-2);
  }
  /* Unlit current-year cell: still mark it */
  .ct-cell.is-now {
    box-shadow: inset 0 -3px 0 var(--color-accent-2);
  }
  /* Lit future cells: dashed accent border */
  .ct-cell.is-lit.is-future {
    background: transparent;
    border-color: var(--color-accent);
    border-style: dashed;
  }

  .ct-year-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-text-mute);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .ct-cell.is-lit.is-past .ct-year-label,
  .ct-cell.is-lit.is-future .ct-year-label {
    color: var(--color-text);
  }
  .ct-cell.is-now .ct-year-label { color: var(--color-accent-2); }

  /* Items inside a cell */
  .ct-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 4px;
    align-content: start;
  }
  .ct-item {
    display: grid;
    grid-template-columns: 6px 1fr;
    column-gap: 5px;
    align-items: start;
    font-size: 10.5px;
    line-height: 1.32;
    color: var(--color-text);
  }
  .ct-item .ct-dot {
    inline-size: 6px;
    block-size: 6px;
    border-radius: 50%;
    margin-block-start: 5px;
    background: var(--color-accent);
  }
  .ct-item--roadmap .ct-dot {
    background: transparent;
    border: 1.5px solid var(--color-accent);
    box-sizing: border-box;
  }
  .ct-item--roadmap .ct-text { color: var(--color-text-mute); }
  .ct-text {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  /* Legend */
  .ct figcaption {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    font-size: var(--text-xs);
    color: var(--color-text-mute);
  }
  .ct-legend { display: inline-flex; align-items: center; gap: 6px; }
  .ct-legend-dot {
    inline-size: 10px;
    block-size: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .ct-legend-dot--past { background: var(--color-accent); }
  .ct-legend-dot--future {
    background: transparent;
    border: 2px solid var(--color-accent);
    box-sizing: border-box;
  }
  .ct-legend-now-box {
    inline-size: 12px;
    block-size: 10px;
    background: color-mix(in srgb, var(--color-accent-2) 14%, transparent);
    border: 1px solid var(--color-accent-2);
    display: inline-block;
    border-radius: 2px;
  }
  .empty { color: var(--color-text-mute); }
</style>
