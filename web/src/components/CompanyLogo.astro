---
/**
 * Company logo with a fallback chain:
 *   1. logo.local (self-hosted under /public)
 *   2. logo.domain → Clearbit's free logo API
 *   3. Letter-monogram (first character of the company name in a coloured circle)
 *
 * The Clearbit case renders both the <img> and a hidden monogram <span>;
 * an inline onerror handler hides the img and shows the monogram if
 * Clearbit returns no image. No JS framework needed.
 */
import type { CompanyLogoSpec } from "../lib/companies.ts";

interface Props {
  name: string;
  logo?: CompanyLogoSpec;
  /** Pixel size for the rendered element (square). */
  size: number;
}

const { name, logo, size } = Astro.props;
const initial = name.trim().charAt(0).toUpperCase();
const local = logo?.local;
const clearbit = logo?.domain ? `https://logo.clearbit.com/${logo.domain}?size=${size * 2}` : null;
const fontSize = Math.round(size * 0.5);
const monogramStyle = `width:${size}px;height:${size}px;font-size:${fontSize}px;`;
---

{local ? (
  <img class="cl-logo" src={local} alt={`${name} logo`} width={size} height={size} loading="lazy" />
) : clearbit ? (
  <span class="cl-logo-wrap" style={`width:${size}px;height:${size}px;`}>
    <img
      class="cl-logo"
      src={clearbit}
      alt={`${name} logo`}
      width={size}
      height={size}
      loading="lazy"
      onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';"
    />
    <span class="cl-monogram cl-monogram--fallback" style={monogramStyle}>{initial}</span>
  </span>
) : (
  <span class="cl-monogram" style={monogramStyle}>{initial}</span>
)}

<style>
  .cl-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cl-logo {
    display: block;
    object-fit: contain;
    border-radius: 6px;
    background: var(--color-bg);
  }
  .cl-monogram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
  .cl-monogram--fallback {
    display: none;
  }
</style>
