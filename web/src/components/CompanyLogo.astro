---
/**
 * Company logo. Resolves to `/logos/<slug>.<ext>` if a file is present in
 * `web/public/logos/` (sourced once per vendor at build time and kept in
 * the repo). Falls back to a letter-monogram in the company's accent
 * colour if the file is missing.
 *
 * Files can be SVG, PNG, or WebP — extension is discovered at build time
 * via a filesystem read, so vendors that only publish PNG don't need any
 * per-vendor metadata.
 */
import fs from "node:fs";
import path from "node:path";
import type { CompanyLogoSpec } from "../lib/companies.ts";

// Build-time lookup: slug → "/logos/slug.ext". Runs once at SSG build.
const LOGO_DIR = path.resolve(import.meta.dirname, "../../public/logos");
const LOGO_BY_SLUG: Record<string, string> = {};
const BASE = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
try {
  for (const file of fs.readdirSync(LOGO_DIR)) {
    const m = file.match(/^(.+)\.(svg|png|webp|jpg|jpeg|gif)$/i);
    if (m) LOGO_BY_SLUG[m[1]] = `${BASE}/logos/${file}`;
  }
} catch {
  // /public/logos missing — every render falls through to the monogram.
}

interface Props {
  name: string;
  slug?: string;
  /** Kept for backward compatibility with existing YAML; not consulted any more. */
  logo?: CompanyLogoSpec;
  /** Pixel size for the rendered element (square). */
  size: number;
}

const { name, slug, size } = Astro.props;
const initial = name.trim().charAt(0).toUpperCase();
const local = slug ? LOGO_BY_SLUG[slug] : null;
const fontSize = Math.round(size * 0.5);
const monogramStyle = `width:${size}px;height:${size}px;font-size:${fontSize}px;`;
---

{local ? (
  <img class="cl-logo" src={local} alt={`${name} logo`} width={size} height={size} loading="lazy" />
) : (
  <span class="cl-monogram" style={monogramStyle}>{initial}</span>
)}

<style>
  .cl-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cl-logo {
    display: block;
    object-fit: contain;
    border-radius: 6px;
    background: var(--color-bg);
  }
  .cl-monogram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
  .cl-monogram--fallback {
    display: none;
  }
</style>
